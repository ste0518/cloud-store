page {
  --color-cream: #FFF8F2;
  --color-card: #FFFFFF;
  --color-primary: #FF9EBB;
  --color-primary-light: #FFD6E7;
  --color-warm: #FFE8A3;
  --color-mint: #D8F5E3;
  --color-text: #4A3B35;
  --color-muted: rgba(74, 59, 53, 0.68);
  --color-line: rgba(255, 158, 187, 0.28);
  --color-field: rgba(255, 255, 255, 0.72);
  --radius-card: 42rpx;
  --radius-inner: 30rpx;
  --shadow-soft: 0 10rpx 0 rgba(255, 214, 231, 0.5), 0 24rpx 48rpx rgba(74, 59, 53, 0.08);
  --shadow-pink: 0 10rpx 0 rgba(224, 120, 153, 0.24), 0 18rpx 32rpx rgba(255, 158, 187, 0.22);

  min-height: 100%;
  background: linear-gradient(180deg, #FFF8F2 0%, #FFF1F7 48%, #FFF8F2 100%);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view,
text,
button,
input,
textarea,
picker,
scroll-view {
  box-sizing: border-box;
  max-width: 100%;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  color: inherit;
  line-height: inherit;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

button::after {
  border: 0;
}

input,
textarea {
  width: 100%;
  min-width: 0;
}

.page {
  width: 100%;
  min-height: 100vh;
  overflow-x: hidden;
  padding: 32rpx 28rpx calc(180rpx + env(safe-area-inset-bottom));
}

.card {
  padding: 32rpx;
  overflow: hidden;
  border: 2rpx solid var(--color-line);
  border-radius: var(--radius-card);
  background: var(--color-card);
  box-shadow: var(--shadow-soft);
}

.page-title {
  color: var(--color-text);
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 0;
  word-break: break-word;
}

.page-subtitle {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 26rpx;
  word-break: break-word;
}

.section-title {
  color: var(--color-text);
  font-size: 31rpx;
  font-weight: 900;
  word-break: break-word;
}

.sweet-button,
.primary-button {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: center;
  width: 100%;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: var(--shadow-pink);
}

.secondary-button {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: center;
  width: 100%;
  border: 1rpx solid var(--color-line);
  border-radius: 999rpx;
  background: var(--color-card);
  color: var(--color-primary);
  font-size: 27rpx;
  font-weight: 800;
}

.soft-button {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: center;
  width: 100%;
  border-radius: 999rpx;
  background: var(--color-primary-light);
  color: var(--color-text);
  font-size: 27rpx;
  font-weight: 800;
}

.danger-button {
  display: flex;
  min-height: 76rpx;
  align-items: center;
  justify-content: center;
  width: 100%;
  border: 1rpx solid rgba(255, 158, 187, 0.42);
  border-radius: 999rpx;
  background: var(--color-card);
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: 800;
}

.field-input,
.field-textarea,
.picker-box {
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-inner);
  background: var(--color-field);
  color: var(--color-text);
}

.empty-card,
.empty-state {
  border: 1rpx dashed rgba(255, 158, 187, 0.46);
  background: rgba(255, 255, 255, 0.72);
  color: var(--color-muted);
  text-align: center;
}

.sticker-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 158, 187, 0.24);
  background: var(--color-primary-light);
  box-shadow: 0 8rpx 0 rgba(255, 158, 187, 0.18);
}

<sweet-nav title="角色入口" show-back="{{editMode}}" />

<view class="page role-page">
  <view class="card hero-card">
    <view class="page-title">欢迎来到云朵小铺 💗</view>
    <view class="page-subtitle">请选择你的身份，再用同一个绑定码连接两个人的订单。</view>
  </view>

  <view class="role-list">
    <view
      wx:for="{{roleOptions}}"
      wx:key="value"
      class="card role-card {{selectedRole === item.value ? 'role-card-active' : ''}} {{lockedActive && item.value !== lockedRole ? 'role-card-disabled' : ''}}"
      data-role="{{item.value}}"
      bindtap="selectRole"
    >
      <view class="role-icon">{{item.icon}}</view>
      <view class="role-main">
        <view class="role-title">{{item.title}}</view>
        <view class="role-desc">{{item.desc}}</view>
      </view>
      <view class="role-check">
        <text>{{lockedActive && item.value !== lockedRole ? '已锁定' : selectedRole === item.value ? '已选' : '选择'}}</text>
      </view>
    </view>
  </view>

  <view class="card bind-card">
    <view class="section-title">绑定码</view>
    <view class="bind-desc">两个人填写同一个绑定码。绑定满两个人后会锁定，其他人不能再进入。</view>

    <view class="avatar-field">
      <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
        <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-initial">{{avatarInitial}}</view>
      </button>
      <view class="avatar-copy">
        <view class="field-label">微信头像</view>
        <view class="bind-desc">只使用你选择的头像，昵称用下面自己填写的称呼。</view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">我的称呼</view>
      <input
        class="field-input"
        value="{{nickname}}"
        placeholder="例如：小皇帝 / 小乖"
        data-field="nickname"
        bindinput="handleInput"
      />
    </view>

    <view class="field">
      <view class="field-label">绑定码</view>
      <view class="code-row">
        <input
          class="field-input code-input"
          value="{{coupleCode}}"
          placeholder="例如：SO-8K3Q9X2A"
          data-field="coupleCode"
          bindinput="handleInput"
        />
        <button class="copy-button" bindtap="copyCode">复制</button>
      </view>
    </view>

    <view class="button-row">
      <button class="soft-button generate-button" bindtap="generateCode">生成绑定码</button>
      <button class="primary-button save-button" bindtap="saveRole">进入小铺</button>
    </view>

    <view class="member-preview">
      <view
        wx:for="{{memberSlots}}"
        wx:key="role"
        class="member-preview-item {{item.hasJoined ? 'member-preview-joined' : ''}} {{item.isMe ? 'member-preview-me' : ''}}"
      >
        <view class="member-avatar-wrap">
          <image wx:if="{{item.avatarUrl}}" class="member-avatar-image" src="{{item.avatarUrl}}" mode="aspectFill" />
          <view wx:else class="member-avatar-initial">{{item.avatarInitial}}</view>
        </view>
        <view class="member-preview-main">
          <view class="member-preview-name">{{item.nickname}}</view>
          <view class="member-preview-status">{{item.roleText}} · {{item.statusText}}</view>
        </view>
      </view>
    </view>
  </view>
</view>

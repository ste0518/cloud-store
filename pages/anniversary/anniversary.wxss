.anniversary-page {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.anniversary-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, var(--color-primary-light) 58%, var(--color-warm) 100%);
}

.countdown-chip {
  flex: 0 0 150rpx;
  padding: 18rpx 14rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  text-align: center;
  box-shadow: 0 10rpx 24rpx rgba(255, 158, 187, 0.12);
}

.countdown-value {
  color: var(--color-primary);
  font-size: 42rpx;
  font-weight: 900;
}

.countdown-label {
  color: var(--color-muted);
  font-size: 23rpx;
}

.nearest-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 26rpx;
  padding: 26rpx;
  border-radius: 38rpx;
}

.nearest-icon,
.anniversary-icon {
  display: flex;
  width: 82rpx;
  height: 82rpx;
  flex: 0 0 82rpx;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: var(--color-primary-light);
  font-size: 42rpx;
  box-shadow: 0 8rpx 0 rgba(255, 158, 187, 0.16);
}

.nearest-main,
.anniversary-main {
  min-width: 0;
  flex: 1;
}

.nearest-title,
.anniversary-title {
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 900;
  word-break: break-word;
}

.nearest-desc,
.anniversary-date,
.anniversary-remark {
  margin-top: 6rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  word-break: break-word;
}

.add-entry-button {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: var(--shadow-pink);
}

.anniversary-empty {
  margin-top: 24rpx;
}

.anniversary-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.anniversary-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 38rpx;
}

.anniversary-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.days-pill {
  flex: 0 0 auto;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: var(--color-warm);
  color: var(--color-text);
  font-size: 22rpx;
  font-weight: 800;
}

.delete-button {
  display: flex;
  min-height: 58rpx;
  flex: 0 0 88rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 158, 187, 0.36);
  border-radius: 999rpx;
  background: var(--color-card);
  color: var(--color-muted);
  font-size: 23rpx;
  font-weight: 800;
}

@media (max-width: 340px) {
  .anniversary-hero,
  .anniversary-card {
    display: block;
  }

  .countdown-chip,
  .anniversary-icon {
    margin-top: 20rpx;
  }

  .anniversary-main,
  .delete-button {
    margin-top: 18rpx;
  }

  .delete-button {
    width: 100%;
    flex-basis: auto;
  }

}

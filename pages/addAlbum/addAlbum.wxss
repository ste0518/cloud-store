.add-album-page {
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

.hero-card {
  border-radius: 46rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, var(--color-primary-light) 58%, var(--color-warm) 100%);
}

.form-card {
  margin-top: 26rpx;
}

.photo-picker {
  display: flex;
  height: 300rpx;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx dashed rgba(255, 158, 187, 0.46);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.72);
}

.photo-picker-filled {
  border-style: solid;
}

.picked-image {
  width: 100%;
  height: 100%;
}

.picker-placeholder {
  color: var(--color-muted);
  text-align: center;
}

.picker-icon {
  color: var(--color-primary);
  font-size: 64rpx;
  font-weight: 800;
}

.picker-text {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.full-field {
  margin-top: 18rpx;
}

.field-label {
  color: var(--color-text);
  font-size: 25rpx;
  font-weight: 900;
}

.field-input,
.picker-box {
  min-height: 78rpx;
  padding: 0 22rpx;
  font-size: 25rpx;
  line-height: 78rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag-pill {
  display: flex;
  min-height: 58rpx;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border: 1rpx solid rgba(255, 158, 187, 0.34);
  border-radius: 999rpx;
  background: var(--color-card);
  color: var(--color-muted);
  font-size: 24rpx;
  font-weight: 800;
}

.tag-pill-active {
  background: var(--color-primary-light);
  color: var(--color-text);
  box-shadow: 0 6rpx 0 rgba(255, 158, 187, 0.14);
}

.submit-button {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: var(--shadow-pink);
}

@media (max-width: 340px) {
  .form-grid {
    grid-template-columns: minmax(0, 1fr);
  }
}

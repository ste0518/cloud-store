.cart-page {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.header-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, var(--color-card) 0%, var(--color-primary-light) 100%);
}

.cloud-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 34rpx;
}

.cloud-main {
  min-width: 0;
  flex: 1;
}

.cloud-title {
  color: var(--color-text);
  font-size: 27rpx;
  font-weight: 900;
}

.cloud-desc {
  margin-top: 6rpx;
  color: var(--color-muted);
  font-size: 23rpx;
  word-break: break-word;
}

.role-button {
  display: flex;
  min-height: 62rpx;
  flex: 0 0 104rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--color-primary-light);
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 900;
}

.empty-card {
  margin-top: 24rpx;
  text-align: center;
}

.empty-icon {
  font-size: 58rpx;
}

.empty-title {
  margin-top: 12rpx;
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.menu-button {
  margin-top: 26rpx;
}

.cart-section,
.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.cart-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 38rpx;
}

.dish-icon {
  display: flex;
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 78rpx;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background: var(--color-primary-light);
  font-size: 42rpx;
  box-shadow: 0 8rpx 0 rgba(255, 158, 187, 0.16);
}

.cart-main {
  min-width: 0;
  flex: 1;
}

.cart-title {
  color: var(--color-text);
  font-size: 31rpx;
  font-weight: 900;
}

.cart-desc {
  margin-top: 6rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.remove-button {
  flex: 0 0 104rpx;
  min-height: 62rpx;
  border: 1rpx solid rgba(255, 158, 187, 0.32);
  border-radius: 999rpx;
  background: var(--color-card);
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 62rpx;
  min-width: 0;
}

.notes-card {
  margin-top: 4rpx;
}

.section-title {
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 900;
}

.notes-input {
  width: 100%;
  min-height: 150rpx;
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(255, 158, 187, 0.2);
  border-radius: 24rpx;
  background: var(--color-cream);
  color: var(--color-text);
  font-size: 27rpx;
  line-height: 1.5;
}

.submit-button {
  display: flex;
  min-height: 86rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 29rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 24rpx rgba(255, 158, 187, 0.22);
}

.submit-button-disabled {
  background: rgba(74, 59, 53, 0.08);
  color: var(--color-muted);
  box-shadow: none;
}

.orders-section {
  margin-top: 38rpx;
}

.orders-empty {
  margin-top: 18rpx;
  color: var(--color-muted);
  text-align: center;
}

.order-card {
  padding: 24rpx;
}

.order-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-title {
  min-width: 0;
  flex: 1;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 900;
}

.status-badge {
  flex: 0 0 auto;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status-pending {
  background: var(--color-warm);
  color: var(--color-text);
}

.status-accepted {
  background: var(--color-mint);
  color: var(--color-text);
}

.status-completed {
  background: var(--color-mint);
  color: var(--color-text);
}

.status-cancelled {
  background: rgba(74, 59, 53, 0.08);
  color: var(--color-muted);
}

.order-notes,
.order-info {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.order-info {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.order-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.order-actions.single {
  grid-template-columns: minmax(0, 1fr);
}

.accept-button,
.cancel-button,
.complete-button {
  display: flex;
  min-height: 72rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.accept-button,
.complete-button {
  background: var(--color-primary);
  color: #FFFFFF;
}

.cancel-button {
  border: 1rpx solid rgba(255, 158, 187, 0.32);
  background: var(--color-card);
  color: var(--color-text);
}

@media (max-width: 340px) {
  .header-card,
  .cloud-card,
  .cart-card,
  .order-top {
    gap: 14rpx;
  }

  .cloud-card {
    flex-direction: column;
    align-items: stretch;
  }

  .role-button {
    width: 100%;
    flex-basis: auto;
  }

  .cart-card {
    display: grid;
    grid-template-columns: 78rpx minmax(0, 1fr);
  }

  .remove-button {
    grid-column: 1 / -1;
    width: 100%;
    flex-basis: auto;
  }

  .order-actions {
    grid-template-columns: minmax(0, 1fr);
  }
}

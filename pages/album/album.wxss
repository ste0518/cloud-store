.album-page {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.album-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, var(--color-primary-light) 58%, var(--color-warm) 100%);
}

.hero-count {
  flex: 0 0 150rpx;
  padding: 18rpx 14rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  text-align: center;
  box-shadow: 0 10rpx 24rpx rgba(255, 158, 187, 0.12);
}

.hero-value {
  color: var(--color-primary);
  font-size: 42rpx;
  font-weight: 900;
}

.hero-label {
  color: var(--color-muted);
  font-size: 23rpx;
}

.cover-card {
  position: relative;
  min-height: 340rpx;
  margin-top: 26rpx;
  overflow: hidden;
  border-radius: 42rpx;
  background: var(--color-card);
  box-shadow: var(--shadow-soft);
}

.cover-image {
  display: block;
  width: 100%;
  height: 340rpx;
}

.cover-mask {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 80rpx 28rpx 26rpx;
  background: linear-gradient(180deg, rgba(74, 59, 53, 0) 0%, rgba(74, 59, 53, 0.58) 100%);
  color: #FFFFFF;
}

.cover-title {
  font-size: 34rpx;
  font-weight: 900;
}

.cover-note {
  margin-top: 6rpx;
  font-size: 25rpx;
  word-break: break-word;
}

.add-entry-button {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: var(--shadow-pink);
}

.album-empty {
  margin-top: 24rpx;
}

.photo-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
}

.photo-card {
  padding: 0;
  overflow: hidden;
  border-radius: 38rpx;
}

.photo-image {
  display: block;
  width: 100%;
  height: 360rpx;
}

.photo-body {
  padding: 24rpx;
}

.photo-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.photo-date,
.photo-note {
  color: var(--color-text);
  font-size: 29rpx;
  font-weight: 900;
  word-break: break-word;
}

.photo-badge,
.meta-pill {
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: var(--color-warm);
  color: var(--color-text);
  font-size: 22rpx;
  font-weight: 800;
}

.photo-note {
  margin-top: 10rpx;
  font-size: 27rpx;
}

.photo-meta,
.photo-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.small-button {
  display: flex;
  min-height: 58rpx;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: var(--color-primary-light);
  color: var(--color-text);
  font-size: 23rpx;
  font-weight: 900;
}

.ghost-button {
  border: 1rpx solid rgba(255, 158, 187, 0.36);
  background: var(--color-card);
  color: var(--color-muted);
}

@media (max-width: 340px) {
  .album-hero {
    display: block;
  }

  .hero-count {
    width: 150rpx;
    margin-top: 20rpx;
  }

}

.blind-page {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.hero-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, var(--color-card) 0%, var(--color-primary-light) 56%, var(--color-warm) 100%);
}

.hero-lock {
  display: flex;
  width: 92rpx;
  height: 92rpx;
  flex: 0 0 92rpx;
  align-items: center;
  justify-content: center;
  border-radius: 30rpx;
  background: #FFFFFF;
  font-size: 48rpx;
  box-shadow: 0 8rpx 0 rgba(255, 158, 187, 0.16);
}

.create-card,
.vote-area,
.role-card,
.input-card,
.gentle-card,
.reveal-card {
  margin-top: 24rpx;
}

.create-hint,
.field-hint,
.vote-subtitle,
.input-subtitle,
.gentle-desc {
  color: var(--color-muted);
  font-size: 24rpx;
}

.create-hint {
  margin-top: 8rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 20rpx;
}

.field-label {
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: 900;
}

.field-input {
  width: 100%;
  min-height: 82rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 158, 187, 0.24);
  border-radius: 30rpx;
  background: var(--color-cream);
  color: var(--color-text);
  font-size: 27rpx;
}

.primary-action {
  display: flex;
  min-height: 84rpx;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: var(--shadow-pink);
}

.vote-card {
  background: var(--color-card);
}

.vote-top,
.input-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.reset-button {
  display: flex;
  min-height: 62rpx;
  flex: 0 0 116rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 158, 187, 0.32);
  border-radius: 999rpx;
  background: var(--color-card);
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 900;
}

.status-row,
.role-row,
.choice-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.status-card {
  padding: 22rpx;
  border: 1rpx solid rgba(255, 158, 187, 0.22);
  border-radius: 32rpx;
  background: var(--color-cream);
  text-align: center;
}

.status-done {
  background: var(--color-primary-light);
}

.status-role {
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 900;
}

.status-icon {
  margin-top: 8rpx;
  font-size: 38rpx;
}

.status-text {
  margin-top: 6rpx;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 900;
}

.role-button,
.suggestion-button {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 158, 187, 0.28);
  border-radius: 999rpx;
  background: var(--color-cream);
  color: var(--color-text);
  font-size: 27rpx;
  font-weight: 900;
  min-width: 0;
}

.role-active {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: #FFFFFF;
  box-shadow: var(--shadow-pink);
}

.secret-chip {
  display: flex;
  min-height: 54rpx;
  flex: 0 0 112rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--color-mint);
  color: var(--color-text);
  font-size: 23rpx;
  font-weight: 900;
}

.suggestion-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.suggestion-button {
  width: auto;
  min-height: 64rpx;
  padding: 0 22rpx;
  background: var(--color-primary-light);
  font-size: 24rpx;
}

.vote-field {
  margin-top: 22rpx;
}

.gentle-card {
  text-align: center;
}

.gentle-icon {
  font-size: 54rpx;
}

.gentle-title {
  margin-top: 10rpx;
  color: var(--color-text);
  font-size: 31rpx;
  font-weight: 900;
}

.gentle-desc {
  margin-top: 8rpx;
}

.reveal-card {
  animation: reveal-pop 0.28s ease both;
  text-align: center;
}

.reveal-kicker {
  color: var(--color-primary);
  font-size: 25rpx;
  font-weight: 900;
}

.choice-card {
  padding: 24rpx;
  border: 1rpx solid rgba(255, 158, 187, 0.24);
  border-radius: 34rpx;
  background: var(--color-cream);
}

.choice-role {
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 900;
}

.choice-text {
  margin-top: 8rpx;
  color: var(--color-text);
  font-size: 31rpx;
  font-weight: 900;
  word-break: break-word;
}

.final-message {
  margin-top: 24rpx;
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 900;
}

.result-box {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-warm));
}

.result-label {
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 800;
}

.result-text {
  margin-top: 6rpx;
  color: var(--color-text);
  font-size: 36rpx;
  font-weight: 900;
  word-break: break-word;
}

.deciding {
  opacity: 0.82;
}

@media (max-width: 340px) {
  .hero-card,
  .vote-top,
  .input-header {
    gap: 14rpx;
  }

  .hero-card {
    flex-direction: column;
  }

  .hero-lock {
    width: 100%;
    flex-basis: 82rpx;
  }

  .status-row,
  .role-row,
  .choice-row {
    grid-template-columns: minmax(0, 1fr);
  }
}

@keyframes reveal-pop {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

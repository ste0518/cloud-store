.add-mood-page {
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

.hero-card {
  border-radius: 46rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, var(--color-primary-light) 58%, var(--color-mint) 100%);
}

.checkin-card {
  margin-top: 26rpx;
}

.mood-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.mood-option {
  min-height: 150rpx;
  padding: 18rpx 10rpx;
  border: 2rpx solid rgba(255, 158, 187, 0.24);
  border-radius: 30rpx;
  background: var(--color-card);
  text-align: center;
}

.mood-option-active {
  border-color: rgba(255, 158, 187, 0.62);
  background: var(--color-primary-light);
  box-shadow: 0 8rpx 0 rgba(255, 158, 187, 0.14);
}

.mood-emoji {
  height: 54rpx;
  font-size: 42rpx;
  line-height: 54rpx;
}

.mood-label {
  margin-top: 8rpx;
  color: var(--color-text);
  font-size: 24rpx;
  font-weight: 900;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.note-field {
  margin-top: 20rpx;
}

.field-label {
  color: var(--color-text);
  font-size: 25rpx;
  font-weight: 900;
}

.field-input {
  min-height: 78rpx;
  padding: 0 22rpx;
  font-size: 25rpx;
  line-height: 78rpx;
}

.submit-button {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: var(--shadow-pink);
}

.recommendation-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 26rpx;
  padding: 26rpx;
  border-radius: 38rpx;
}

.recommendation-icon {
  display: flex;
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 78rpx;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background: var(--color-primary-light);
  font-size: 40rpx;
  box-shadow: 0 8rpx 0 rgba(255, 158, 187, 0.16);
}

.recommendation-main {
  min-width: 0;
  flex: 1;
}

.recommendation-title {
  color: var(--color-text);
  font-size: 29rpx;
  font-weight: 900;
  word-break: break-word;
}

.recommendation-desc {
  margin-top: 6rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  word-break: break-word;
}

.recommendation-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.meta-pill {
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: var(--color-warm);
  color: var(--color-text);
  font-size: 22rpx;
  font-weight: 800;
}

@media (max-width: 340px) {
  .recommendation-card {
    display: block;
  }

  .mood-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .recommendation-icon {
    margin-top: 20rpx;
  }

  .recommendation-main {
    margin-top: 18rpx;
  }
}

.menu-page {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.menu-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, var(--color-card) 0%, var(--color-primary-light) 100%);
}

.dish-count {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 800;
}

.header-side {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.add-dish-button {
  display: flex;
  min-height: 58rpx;
  min-width: 104rpx;
  width: 112rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: var(--shadow-pink);
}

.category-scroll {
  width: 100%;
  margin-top: 26rpx;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx 8rpx 16rpx 2rpx;
}

.category-chip {
  display: inline-flex;
  min-width: 112rpx;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border: 2rpx solid rgba(255, 158, 187, 0.22);
  border-radius: 999rpx;
  background: var(--color-card);
  color: var(--color-muted);
  font-size: 25rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(74, 59, 53, 0.06);
}

.category-chip-active {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: #FFFFFF;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 24rpx;
}

.dish-card {
  padding: 28rpx;
  border-radius: 42rpx;
}

.dish-top {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.dish-icon {
  display: flex;
  width: 82rpx;
  height: 82rpx;
  flex: 0 0 82rpx;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: var(--color-primary-light);
  font-size: 44rpx;
  box-shadow: 0 8rpx 0 rgba(255, 158, 187, 0.16);
}

.dish-main {
  min-width: 0;
  flex: 1;
}

.dish-name {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 900;
}

.dish-desc {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 25rpx;
}

.dish-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--color-warm);
  color: var(--color-text);
  font-size: 23rpx;
  font-weight: 700;
}

.dish-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.dish-actions-single {
  grid-template-columns: minmax(0, 1fr);
}

.cart-button,
.delete-button {
  display: flex;
  min-height: 76rpx;
  width: 100%;
  min-width: 0;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.cart-button {
  background: var(--color-primary);
  color: #FFFFFF;
  box-shadow: 0 12rpx 24rpx rgba(255, 158, 187, 0.2);
}

.delete-button {
  border: 1rpx solid rgba(255, 158, 187, 0.32);
  background: var(--color-card);
  color: var(--color-text);
}

@media (max-width: 340px) {
  .menu-header,
  .dish-top {
    gap: 16rpx;
  }

  .dish-actions {
    grid-template-columns: minmax(0, 1fr);
  }

}

.empty-card {
  margin-top: 24rpx;
  text-align: center;
}

.empty-icon {
  font-size: 58rpx;
}

.empty-title {
  margin-top: 12rpx;
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.empty-action {
  display: flex;
  min-height: 72rpx;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 900;
}
